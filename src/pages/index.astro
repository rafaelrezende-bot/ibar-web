  .faq-item__answer{max-height:0;overflow:hidden;transition:max-height .3s}
  .faq-item.active .faq-item__answer{max-height:200px}
  .faq-item__answer-inner{padding:0 20px 24px;font-size:14px;color:var(--dark);line-height:1.6}

  .cta-contato{background:var(--darkest);padding:80px 0}
  .cta-contato__inner{max-width:720px;margin:0 auto;text-align:center;padding:0 64px}
  .cta-contato__title{font-size:36px;font-weight:700;color:var(--white);margin-bottom:16px}
  .cta-contato__subtitle{font-size:18px;color:var(--light);margin-bottom:32px;line-height:1.5}

  .footer{background:var(--darkest);border-top:1px solid var(--dark);padding:64px}
  .footer__grid{max-width:var(--max-width);margin:0 auto;display:grid;grid-template-columns:2fr 1fr 1fr 1fr 1fr;gap:32px}
  .footer__logo{font-size:24px;font-weight:700;color:var(--white);margin-bottom:16px}
  .footer__address{font-size:14px;color:var(--medium);line-height:1.5}
  .footer__col-title{font-size:14px;font-weight:600;color:var(--white);margin-bottom:16px}
  .footer__links{display:flex;flex-direction:column;gap:10px}
  .footer__links a{font-size:14px;color:var(--medium);transition:color .2s}
  .footer__links a:hover{color:var(--light)}
  .footer__bottom{max-width:var(--max-width);margin:32px auto 0;padding-top:32px;border-top:1px solid var(--dark);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px}
  .footer__copyright{font-size:12px;color:var(--medium)}
  .footer__legal{display:flex;gap:24px}
  .footer__legal a{font-size:12px;color:var(--medium);transition:color .2s}
  .footer__legal a:hover{color:var(--light)}

  @media(max-width:1024px){
    .hero__content{padding:48px 32px;padding-top:120px}
    .empresa-card--side{width:260px;height:360px}
    .empresa-card--center{width:320px;height:420px}
    .empresa-card--center .empresa-card__name{font-size:26px}
    .industrias__grid{grid-template-columns:repeat(2,1fr)}
    .cadeia__grid{grid-template-columns:repeat(2,1fr)}
    .numeros__grid{grid-template-columns:repeat(2,1fr);gap:40px}
    .footer__grid{grid-template-columns:repeat(2,1fr)}
    .footer{padding:48px 32px}
    .depoimentos__track-wrapper{margin:0 -80px;padding:0 80px}
    .depoimento-card{min-width:320px;max-width:320px}
  }
  @media(max-width:768px){
    .header__nav,.header__icons{display:none}
    .header__menu-toggle{display:block}
    .header{padding:14px 20px}
    .hero{min-height:500px}
    .hero__content{padding:32px 20px;padding-top:100px}
    .hero__title{font-size:28px}
    .hero__subtitle{font-size:14px}
    .hero__ctas{flex-direction:column}
    .hero__ctas a{text-align:center}
    .empresas{padding:48px 0}
    .empresas__title{font-size:22px;padding:0 20px}
    .empresas__carousel{flex-direction:column;gap:12px;align-items:center}
    .empresa-card--side,.empresa-card--center{width:90%;max-width:360px;height:300px;opacity:1}
    .empresa-card--center .empresa-card__name,.empresa-card--side .empresa-card__name{font-size:22px}
    .industrias{padding:48px 0}
    .industrias__title{font-size:22px}
    .industrias__grid{grid-template-columns:1fr}
    .industrias__chips{padding:0 20px}
    .cadeia{padding:48px 0}
    .cadeia__title{font-size:22px;padding:0 20px}
    .cadeia__grid{grid-template-columns:1fr}
    .numeros{padding:48px 0}
    .numeros__title{font-size:22px;padding:0 20px}
    .numeros__grid{grid-template-columns:1fr 1fr;gap:32px}
    .numero-item__value{font-size:40px}
    .depoimentos{padding:48px 0}
    .depoimentos__title{font-size:22px;padding:0 20px}
    .depoimentos__track-wrapper{margin:0 -40px;padding:0 40px}
    .depoimento-card{min-width:280px;max-width:280px;padding:24px 20px}
    .faq{padding:48px 0}
    .faq__inner{padding:0 20px}
    .faq__title{font-size:22px}
    .cta-contato{padding:48px 0}
    .cta-contato__inner{padding:0 20px}
    .cta-contato__title{font-size:26px}
    .cta-contato__subtitle{font-size:16px}
    .footer{padding:32px 20px}
    .footer__grid{grid-template-columns:1fr;gap:32px}
    .footer__bottom{flex-direction:column;align-items:flex-start}
  }
</style>

<script>
  // Header hide/show
  let lastY = window.scrollY;
  const header = document.getElementById('header')!;
  window.addEventListener('scroll', () => {
    const y = window.scrollY;
    header.classList.toggle('header--hidden', y > lastY && y > 100);
    lastY = y;
  }, { passive: true });

  // Mobile nav
  document.getElementById('menuOpen')!.addEventListener('click', () => document.getElementById('mobileNav')!.classList.add('active'));
  document.getElementById('menuClose')!.addEventListener('click', () => document.getElementById('mobileNav')!.classList.remove('active'));
  document.querySelectorAll('.mobile-nav a').forEach(a => a.addEventListener('click', () => document.getElementById('mobileNav')!.classList.remove('active')));

  // Chips
  document.querySelectorAll('.chip').forEach(chip => {
    chip.addEventListener('click', () => {
      document.querySelectorAll('.chip').forEach(c => c.classList.remove('chip--active'));
      chip.classList.add('chip--active');
    });
  });

  // FAQ
  document.querySelectorAll('.faq-item__header').forEach(btn => {
    btn.addEventListener('click', () => btn.parentElement!.classList.toggle('active'));
  });

  // Empresas carousel
  const empresasData = [
    { name: 'IBAR Refratários', img: 'https://images.unsplash.com/photo-1513828583688-c52646db42da?w=600' },
    { name: 'IBAR Nordeste', img: 'https://images.unsplash.com/photo-1565193566173-7a0ee3dbe261?w=600' },
    { name: 'IBAR Poá', img: 'https://images.unsplash.com/photo-1581091226033-d5c48150dbaa?w=600' },
    { name: 'Nutec IBAR', img: 'https://images.unsplash.com/photo-1504917595217-d4dc5ebe6122?w=600' },
    { name: 'Global Service', img: 'https://images.unsplash.com/photo-1558618666-fcd25c85f82e?w=600' },
    { name: 'Biolã', img: 'https://images.unsplash.com/photo-1504328345606-18bbc8c9d7d1?w=600' },
  ];
  const pages = [[5,0,1],[1,2,3],[3,4,5]];
  let currentPage = 0, paused = false;
  const cards = document.querySelectorAll('.empresa-card');
  const dots = document.querySelectorAll('[data-dot]');

  function updateCarousel() {
    const page = pages[currentPage];
    cards.forEach((card, i) => {
      const e = empresasData[page[i]];
      card.querySelector('.empresa-card__name')!.textContent = e.name;
      (card.querySelector('.empresa-card__bg') as HTMLElement).style.backgroundImage = `url(${e.img})`;
    });
    dots.forEach(dot => {
      const idx = parseInt(dot.getAttribute('data-dot')!);
      dot.className = idx === currentPage ? 'dot dot--active' : 'dot dot--inactive';
    });
  }

  setInterval(() => { if (!paused) { currentPage = (currentPage + 1) % pages.length; updateCarousel(); } }, 3500);
  document.getElementById('empresasPause')!.addEventListener('click', function(this: HTMLElement) { paused = !paused; this.textContent = paused ? '\u25B6' : '\u2758\u2758'; });
  dots.forEach(dot => dot.addEventListener('click', () => { currentPage = parseInt(dot.getAttribute('data-dot')!); updateCarousel(); }));

  // Testimonials auto-scroll
  const track = document.querySelector('.depoimentos__track') as HTMLElement;
  if (track) {
    let scrollAmt = 0;
    let interval = setInterval(() => { scrollAmt += 404; if (scrollAmt >= track.scrollWidth - track.clientWidth) scrollAmt = 0; track.scrollTo({ left: scrollAmt, behavior: 'smooth' }); }, 4000);
    track.addEventListener('mouseenter', () => clearInterval(interval));
    track.addEventListener('mouseleave', () => { interval = setInterval(() => { scrollAmt += 404; if (scrollAmt >= track.scrollWidth - track.clientWidth) scrollAmt = 0; track.scrollTo({ left: scrollAmt, behavior: 'smooth' }); }, 4000); });
  }
</script>
